#define MCU_ERR_MSG                 $FF1001 /* MCU error string (basename/chip name, NUL-term), $FF1001..$FF1040. NB overlaps SRAM_PARAM_ADDR($FF1004) on the MCU side -- benign, PARAM already consumed in this flow. */
/* error codes -- must match MENU_ERR_* in src/snes.h */
#define MENU_ERR_SUPPLFILE          $02
#define MENU_ERR_NOIMPL             $03
