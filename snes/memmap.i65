#define CMD_CLR_MENU_SPC            $2f /* clear CFG.bgm_name -> menu BGM falls back to /sd2snes/menu.spc */
/* WiFi-in-menu commands RESERVED for the Companion port (lockstep with src/snes.h):
   WiFi owns $30-$33, so game-info lives at $34-$37. No menu/MCU handler in this
   branch -- reserved so adding WiFi later needs zero command renumbering. */
#define CMD_WIFI_SCAN               $30 /* RESERVED (Companion): queue an AP scan on the ESP */
#define CMD_WIFI_GET                $31 /* RESERVED (Companion): write current status + scan list to WIFI_BLK */
#define CMD_WIFI_CONNECT            $32 /* RESERVED (Companion): connect using ssid/pass written to WIFI_BLK */
#define CMD_WIFI_FORGET             $33 /* RESERVED (Companion): forget the saved network */
#define CMD_GAME_INFO               $34 /* parse /sd2snes/info/<rom>.yml + stage cover/screenshot (non-booting, like LOAD_COVER) */
#define CMD_GAME_INFO_RECENT        $35 /* GAME_INFO for the recent game at MCU_PARAM index (LAST_FILE) */
#define CMD_GAME_INFO_FAVORITE      $36 /* GAME_INFO for the favorite game at MCU_PARAM index (FAVORITES_FILE) */
#define CMD_FMV_NEXT                $37 /* info-screen FMV pump: stream next <rom>.fmv frame into GI_TILES ($CA0000) for the menu to re-DMA (gameinfo_fmv_next); non-booting */
#define CMD_GI_DESC_FULL            $38 /* stage the full (untruncated) description into GI_DESC_EXT ($FF7600) NUL-term; non-booting */
#define SFX_MAILBOX                 $002BE0 /* fork: menu sound effects mailbox (sfx.a65 <-> MCU menu loop). Value = effect+1 (1-4: cursor/confirm/back/error), 0 = consumed. DEDICATED byte: sharing MCU_CMD raced the real commands. NOT $2A08: MCU_PARAM is a 12-BYTE region ($2A04-$2A0F, settime writes +11) - parking there corrupted cover requests and saved garbled favorites. $2BE0 sits in the unreferenced $2BB4-$2BEF gap. Newest-wins, fire-and-forget. */

/* WiFi status/scan block + connect params, RESERVED for the Companion port.
   Own dedicated 437-byte block ($FF4000..$FF41B5) in the free gap left by the old
   favorites slot ($FF4000..$FF49FF, vacated when favorites moved to $FF6000) -- no
   longer aliases SYSINFO_BLK, so the WiFi and sysinfo screens can coexist. Layout
   MUST match src/snes.h WIFI_OFF_* (lockstep with SRAM_WIFI_ADDR in src/memory.h). */
#define WIFI_BLK                    $FF4000
#define WIFI_OFF_CONNECTED          0    /* u8 */
#define WIFI_OFF_RSSI               1    /* i8 */
#define WIFI_OFF_SSID               2    /* char[33] */
#define WIFI_OFF_IP                 35   /* char[16] */
#define WIFI_OFF_SCAN_CNT           51   /* u8 */
#define WIFI_OFF_SCAN_SEQ           52   /* u8 */
#define WIFI_OFF_APS                53   /* scan_cnt * {i8 rssi, u8 enc, char ssid[33]} */
#define WIFI_AP_STRIDE              35
#define WIFI_OFF_REQ_SSID           340  /* char[33] - menu writes (CONNECT) */
#define WIFI_OFF_REQ_PASS           373  /* char[64] - menu writes (CONNECT) */

/* IPS patch list written by MCU. Layout: +0 num_patches, +1 display names
   (8*IPS_NAME_LEN=512 -> [1,513)), +520 full SD paths (8*256=2048 -> [520,2568)),
   region $FF5000..$FF5A08, below FAVORITE_GAMES $FF6000. The menu reads only the
   name region here; the paths are consumed by the MCU (IPS_PATH_BASE in src/patch.h).
   Lockstep with SRAM_IPS_LIST_ADDR in src/memory.h. */
#define IPS_LIST                    $FF5000  /* IPS patch list written by MCU */
#define IPS_NAME_LEN                64       /* bytes per display name entry */
#define IPS_MAX_PATCHES             8        /* maximum patches per ROM */
#define CMD_SAVESTATE               $40
#define CMD_LOADSTATE               $41
#define CMD_CHEAT_REPROGRAM         $42 /* in-game cheat overlay: reconcile BSRAM flag mirror ($FF0500) into canonical records + re-deploy cheats live */
