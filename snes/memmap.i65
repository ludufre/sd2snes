.link page $c0
#define APUIO0                      $2140
#define APUIO1                      $2141
#define APUIO2                      $2142
#define APUIO3                      $2143

#define BG1_TILE_BASE               $5800
#define BG2_TILE_BASE               $5000

#define OAM_TILE_BASE               $6000

/* ---- cover preview (16x16 OBJ sprites floating over the file list) ----
   The cover is drawn with OBJ sprites (independent of the BG mode), so the file
   list keeps its full Mode-5 hi-res 18 rows. It is a w_spr x h_spr grid of 16x16
   sprites, 4bpp, up to 8 OBJ palettes (CGRAM 128..255), one palette per 16x16
   block (the BLOCKMAP). The 4bpp tiles live in the FREED BG-cover VRAM region:
   OBJ name base $2000 (256 tiles). The cover floats OPAQUE (OBJ priority 3) over
   the top of the list. The MCU stages the cover into bank C9 (CMD_LOAD_COVER,
   see src/cover.c, .cov v4). The whole upload is done synchronously in forced
   blank (no VBlank overrun, no NMI work). The list/band/logo are untouched. */
#define COVER_OBJ_VRAM_BASE         $2000      /* OBJ name-table base (VRAM words) */
#define COVER_OBJ_CLEAR_LEN         $2000      /* bytes cleared at init (256 4bpp tiles) */
#define COVER_OBSEL                 $01        /* $2101: size tbl0 (8/16), name sel 0, base $2000 */
/* The header logo is now FULL-WIDTH (cols 0..31), so there is no blank cover area
   to fill: the old COVER_BLANK_VRAM/COVER_BLANK_CHAR tile is gone. */
#define COVER_OBJ_X_RIGHT           256        /* right edge of the cover = screen edge; the
                                                  256 wrap is handled in cover_build_oam (lda #0). */
#define COVER_OBJ_Y0                0          /* TEMP: top-right (Y=0) to preview overlap vs header */
#define COVER_OBJ_MAX_W             8          /* 16-wide name grid -> <= 8 sprites wide */
#define COVER_OBJ_MAX_H             8          /* 256-tile page -> <= 8 sprites tall */
#define COVER_OBJ_ATTR              $30        /* OAM attr base: OBJ priority 3 (bits5-4), no flip */
#define COVER_OAM_FIRST             0          /* first OAM slot used by the cover */
#define COVER_OAM_LO_BYTES          256        /* 64 sprites * 4 bytes (whole cover OAM low table) */
#define COVER_OAM_HI_BYTES          16         /* 64 sprites / 4 (whole cover OAM high table) */
#define COVER_DEBOUNCE              6          /* frames to settle before requesting (must stay
                                                  > the 3-frame d-pad auto-repeat so held scrolling
                                                  never fires a cover; 6 = faster load, still safe) */
#define COVER_TIMEOUT               180        /* frames before giving up on the MCU */
/* ---- header logo (8bpp BG1, FULL-WIDTH 256x56; baked tiles in logo.a65) ----
   The logo lives permanently in BG1_TILE_BUF cols 0..31 (written once at init);
   the OBJ cover floats below it (COVER_OBJ_Y0), so the logo is never overwritten. */
#define COVER_LOGO_VRAM            $6000      /* VRAM word dest for logo tile 0 (= char $300) */
#define COVER_LOGO_CHAR            $0300      /* BG1 char number of logo tile 0 */
#define COVER_LOGO_CGB             $40        /* CGRAM 64: logo palette base (pal 4+5, free) */
#define COVER_LOGO_COLS            32         /* logo width in 8px tiles (256px, full-width cols 0..31) */
#define COVER_LOGO_TILEBYTES       $3800      /* 32*7*64 = 14336 bytes */
#define COVER_LOGO_PALBYTES        $0040      /* 32 colours * 2 = 64 bytes */
/* bank-C9 staging layout (must match src/cover.h COVER_OFF_*) */
#define SRAM_COVER_ADDR             $C90000
#define COVER_C9_TILES              $C90000    /* 4bpp tiles (name-grid order) */
#define COVER_C9_PAL                $C92000    /* up to 8 OBJ palettes, 16 BGR555 each */
#define COVER_C9_BLOCKMAP           $C92100    /* per-16x16-block palette index (0..7) */
#define COVER_C9_STATUS             $C93A00    /* meta: status,w_spr,h_spr,npal,rsvd,flags */
#define COVER_C9_META_W             $C93A01    /* w_spr */
#define COVER_C9_META_H             $C93A02    /* h_spr */
#define COVER_C9_META_NPAL          $C93A03    /* n_palettes */
#define COVER_STATUS_OK             $01

/* ---- pre-boot game info screen (snes/gameinfo.a65) ----
   One composited DirectColor (CG-Direct-Select) BG1 image (cover + screenshot,
   utils/gen_dcimage.py) is staged by the MCU (CMD_GAME_INFO): 8bpp tiles -> bank
   $CA, 16-bit tilemap -> bank $CB. The parsed metadata struct lands at GAMEINFO
   ($FF6000); the menu reads it by fixed offset (mirror src/gameinfo.h). */
#define GI_TILES                    $CA0000    /* 8bpp DirectColor tiles (.gd) / FMV frame tiles (.fmv) */
#define GI_FMV_PAL                  $CA1B00    /* .fmv v3: FMV frame palette (256B) right after the 6912B frame at GI_TILES; -> CGRAM 128 */
#define GI_TMAP                     $CB0000    /* 16-bit BG tilemap (.gd) / .fmv v3 cover palette (160B) -> CGRAM 48 */
/* paletted band cover region (left): 16x16 tiles (128x128px) at col 1. Cover tiles DMA to window-0
   ($2000 = char #256); 256 tiles span #256..511 ($2000..$3FFF) -- MUST stay <= 256 tiles or it spills
   into $4000 (the body's BG2 font), corrupting the background (the bottom cover row overwrote BG2
   font #0..31). 17 wide (272 tiles, -> $41FF) did exactly that. Cell (r,c) -> char GI_COVER_CHAR0 + r*GI_COVER_W + c. */
#define GI_COVER_CHAR0              $0100      /* window-0 first tile char (#256) */
#define GI_COVER_COL0              1          /* cover left column in the 32-wide band (px 8) */
#define GI_COVER_ROW0              0
#define GI_COVER_W                 16         /* cover width  in tiles (128 px) */
#define GI_COVER_H                 16         /* cover height in tiles (128 px) -- 16x16 = 256 = window-0 cap */

/* gameinfo_meta_t. MUST sit AFTER the favorites mirror ($FF6000..$FF73FF) -- overlapping it
   clobbers the favorites list when a favorite's info panel opens. Lockstep with src/memory.h. */
#define GAMEINFO                    $FF7400    /* gameinfo_meta_t (src/gameinfo.h) */
#define GI_STATUS                   $FF7402    /* 0 NONE, 1 OK, 2 ERROR */
#define GI_FLAGS                    $FF7403    /* bit0 = image.gd staged */
#define GI_IMG_W                    $FF7404    /* image width in 8x8 tiles */
#define GI_IMG_H                    $FF7405    /* image height in tiles */
#define GI_IMG_NTILES               $FF7406    /* unique tiles (uint16) */
#define GI_TITLE                    $FF7408    /* char[40] font-encoded */
#define GI_DEVELOPER                $FF7430    /* char[40] */
#define GI_YEAR                     $FF7458    /* char[6]  e.g. "1994" */
#define GI_PLAYERS                  $FF745E    /* char[4]  e.g. "2" */
#define GI_GENRE                    $FF7462    /* char[32] */
#define GI_CHIP                     $FF7482    /* char[24] */
#define GI_DESCRIPTION              $FF749A    /* char[256] one line; menu word-wraps */
#define GI_FMV_FPS                  $FF759A    /* FMV playback fps (when GI_FLAG_FMV) */
#define GI_FMV_FRAMES               $FF759B    /* FMV total frames (uint16; info/debug) */
#define GI_DESC_EXT                 $FF7600    /* full description char[2048] NUL-term staged by CMD_GI_DESC_FULL;
                                                  first byte 0 = invalid -> menu falls back to GI_DESCRIPTION;
                                                  lockstep with SRAM_GAMEINFO_DESCEXT_ADDR in src/memory.h */
#define GI_STATUS_OK                $01
#define GI_FLAG_IMAGE               $01        /* legacy DirectColor .gd (RETIRED; band is paletted) */
#define GI_FLAG_FMV                 $02        /* cover-LESS <rom>.fmv v4 screenshot/animation staged at
                                                  GI_TILES ($CA0000); 1 frame = static, N = animated;
                                                  pumped by CMD_FMV_NEXT (see snes/gameinfo.a65) */
#define GI_FLAG_COVER               $04        /* <rom>.gcv paletted 120c cover staged (CGRAM 48..167);
                                                  without it the cover region shows the gradient */
#define GI_FLAG_COVER_OBJ           $08        /* FALLBACK (no .gcv): the <rom>.cov staged in C9 -> float it
                                                  as OBJ box-art CENTERED in the .gcv 128x128 cover box.
                                                  Mutually exclusive with GI_FLAG_COVER (.gcv wins). */
/* ---- small (half-size) cover: WRAM scratch + downscale LUT ----
   When ShowCovers == 2 the menu resamples the staged 16x16-block tiles down to
   one 8x8 tile per block (nearest-neighbour, even pixels) into COVER_SMALL_TILEBUF,
   then draws the cover as 8x8 OBJ sprites (COVER_OBSEL already selects the 8/16
   size pair). COVER_PACKTBL is a 256-byte LUT that gathers a byte's 4 even bits
   into the low nibble; it is built once at boot. Both live in free WRAM after the
   cover OAM shadow ($7EC000+256) and below WRAM_ROUTINE ($7EF000). */
#define COVER_SMALL_TILEBUF         $7EC100    /* resampled 8x8 tiles (dense, <= w*h*32 = 2048 B) */
#define COVER_PACKTBL               $7ED100    /* 256-byte even-bit-pack LUT (built at init) */
#define COVER_PACKTBL_W             $D100      /* low 16 of COVER_PACKTBL for abs,Y reads (DB=$7E) */
#define COVER_SMALL_OBJ_STEP        8          /* small sprite pitch in px (8x8 OBJ) */

#define MCU_CMD                     $002A00
#define SNES_CMD                    $002A02
#define MCU_PARAM                   $002A04
#define BRAM_ROUTINE                $002A10
#define WARM_SIGNATURE              $002AFD
#define WARM_COMPLEMENT             $002AF9
#define SAVED_SP                    $002AFB

#define BGM_STATE                   $002AF7 /* fork: menu-music runtime state. Lives in the $2A
                                              FPGA region, which is NOT cleared by clear_wram and
                                              survives a reset, so coldboot explicitly zeroes it
                                              (main.a65) -- every non-warm reset lands in coldboot.
                                              0=not loaded (reload), 1=playing, 2=tried-no-spc,
                                              3=music off + DSP-unmute stub running (keeps the
                                              cart MSU-1 DAC audible for the menu sound effects),
                                              4=tried-no-spc + DSP-unmute stub running. */

