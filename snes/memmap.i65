#define NUM_CHEATS                  $FF0700
#define CHEAT_OVL_GATE              $FF0710 /* in-game cheat overlay arm flag, set by firmware at game load (= CFG.enable_cheat_overlay && !special_chip). The savestate-handler probe reads it; 0 => don't open. Free $FF0701..$FF07FF gap. */
#define CHEAT_ADDR                  $D00000
#define CHEAT_CODE_STRINGS          $D40000 /* per-code display strings, 12 bytes each. cheat_idx*512 + code_idx*12. Spans banks D4..D7 to leave D0..D3 free for up to 512 cheat records (512 bytes each). */
#define CHEAT_TITLE                 $D80000 /* 256 bytes "Cheats for <game>" null-terminated, in cheat region past any plausible cheat count */
#define CHEAT_FLAGS                 $FF0500 /* 512 bytes BSRAM mirror of cheat flag byte 0 (cheats 0..511). SNES reads/writes here for instant visual toggle, MCU also keeps it in sync. */
#define CHEAT_NAMES                 $FF0800 /* in-game cheat overlay: first CHEAT_OVL_MAX names, CHEAT_NAME_LEN bytes each, staged by firmware at game load ($D00000 records are game ROM in-game). 64*32=2KB fills $FF0800..$FF0FFF. */
#define CHEAT_OVL_MAX               64      /* in-game overlay covers the first 64 cheats */
#define CHEAT_NAME_LEN              32      /* bytes per staged in-game name */

#define SPC_DATA                    $FD0000
#define SPC_HEADER                  $FE0000
