#define BGM_STATE                   $002AF7 /* fork: menu-music runtime state. Lives in the $2A
                                              FPGA region, which is NOT cleared by clear_wram and
                                              survives a reset, so coldboot explicitly zeroes it
                                              (main.a65) -- every non-warm reset lands in coldboot.
                                              0=not loaded (reload), 1=playing, 2=tried-no-spc. */

