#define CFG_ENABLE_MENU_SFX             CFG_ADDR+$00BB
#define CFG_MENU_MUSIC_FILE             CFG_ADDR+$00BC
#define CFG_SORT_FAVORITES              CFG_ADDR+$013C
#define CFG_ENABLE_CHEAT_OVERLAY        CFG_ADDR+$013D
#define CFG_SHOW_GAME_INFO              CFG_ADDR+$013E
#define CFG_ENABLE_WIFI                 CFG_ADDR+$013F /* RESERVED (Companion master switch). Placed at $13F (NOT $BD: that overlapped CFG_MENU_MUSIC_FILE $BC, 128B) so the WiFi port slots in with no cfg-offset drift. Lockstep with src/cfg.h. */
#define CFG_GAME_INFO_VIDEO             CFG_ADDR+$0140 /* play the .fmv clip on the game info screen (off -> static .gss snapshot) */
#define CFG_GAME_INFO_MUSIC             CFG_ADDR+$0141 /* play the clip's .pcm soundtrack (requires CFG_GAME_INFO_VIDEO) */

#define MENU_ENTRY_SIZE             23
#define FAV_VISMAX                  13 /* max favorites rows shown at once (window at last_win_y=12 -> rows 12..26, status bar 27); the rest scroll */

#define ST_RTC_VALID                ST_MCU_ADDR+$0000
#define ST_NUM_RECENT_GAMES         ST_MCU_ADDR+$0001
#define ST_PAIRMODE                 ST_MCU_ADDR+$0002
#define ST_NUM_FAVORITE_GAMES       ST_MCU_ADDR+$0003
#define ST_AUTOBOOT_ENABLED         ST_MCU_ADDR+$0004
#define ST_RESET_TO_MENU_ACTIVE     ST_MCU_ADDR+$0005
#define ST_FAVORITES_FULL           ST_MCU_ADDR+$0006 /* 1 if the last add-favorite was refused (list full) */

#define ST_IS_U16                   ST_SNES_ADDR+$0000
#define ST_U16_CFG                  ST_SNES_ADDR+$0001
#define ST_HAS_SATELLAVIEW          ST_SNES_ADDR+$0002

#define MTYPE_FUNC                  $01
#define MTYPE_SUBMENU               $02
#define MTYPE_VALUE                 $03
#define MTYPE_FUNC_CLOSE            $04

#define OPTTYPE_NONE                $00
