  sta window_h
  jsr push_window
  jsr window_greyout
  lda #$06
  sta window_x
  lda #$0b
  sta window_y
  phb
    lda #^menu_enttab_filesel_context_file
    pha
    plb
    ldx #!menu_enttab_filesel_context_file
    jsr show_menu
  plb
  jsr pop_window
  rts

