.link page $c0

#include "memmap.i65"
#include "dma.i65"
#include "stack.i65"

#define MENU_NUM_DATA_TYPES $07

; ---- description box (mdesc_* of the selected menu item) ----
; The box hugs the text: width = longest wrapped line + 4, aligned under the menu
; (desc_box_x = menu window_x), wrapped at desc_iw = DESC_RIGHT - x - 3.
#define DESC_RIGHT        $3d       ; rightmost usable column (61, edge of greyed area)
#define DESC_TOPROW       $09       ; first usable row (just below the header)
#define DESC_BOTROW       $1a       ; last usable row (26, above the blank row + status bar/clock)
#define MAX_DESC_LINES    $06       ; cap on description lines (and box height)

mainmenu:
  sep #$20 : .as
  rep #$10 : .xl
  lda #$02
  sta window_x
  lda #$09
  sta window_y
  lda #60
  sta window_w
  lda #18
  sta window_h
  jsr push_window
  jsr window_greyout
  lda #$01
  sta mainmenu_active
  stz egg_shown
mainmenu_reshow:
  sep #$20 : .as
  stz mainmenu_relang        ; cleared each pass; set by show_menu on a language change
  lda #$06
  sta window_x
  lda #$0b
  sta window_y
  phb
    lda #^menu_enttab_mm
    pha
    plb
    ldx #!menu_enttab_mm
    jsr show_menu
  plb
  lda mainmenu_relang        ; language switched -> reopen the menu fresh (new widths)
  beq +
  jsr filesel_statusbar      ; refresh the (visible, un-greyed) browser statusbar now,
  bra mainmenu_reshow        ; so it follows the new language together with the menu
+ stz mainmenu_active
  jsr pop_window
  rts

