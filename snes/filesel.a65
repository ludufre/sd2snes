.link page $c0

#include "memmap.i65"
#include "dma.i65"

filesel_init:
  sep #$20 : .as
  rep #$10 : .xl
  lda #^ROOT_DIR
  ldx #!ROOT_DIR
  sta dirptr_bank
  stx dirptr_addr
  sta dirstart_bank
  stx dirstart_addr
  stz filesel_state
  stz dirend_onscreen
  lda #$02
  sta cursor_x
  lda #$09
  sta cursor_y
  lda #$01
  sta bar_xl
  lda #$3e
  sta bar_wl
  ldx #$0000
  stx dirptr_idx
  stx filesel_sel
  stx direntry_xscroll
  stx direntry_xscroll_state
  lda #$01
  sta filesel_dirty
  rep #$20 : .al
  lda #!dirlog
  sta dirlog_idx
  sep #$20 : .as
  lda #^dirlog
  sta dirlog_idx+2
  lda #$2f
  sta @FILESEL_CWD
  lda #$00
  sta @FILESEL_CWD+1
  jsr filesel_request_filelist
  rts

fileselloop:
  sep #$20 : .as
  rep #$10 : .xl
  lda isr_done
  lsr
  bcc fileselloop
  stz isr_done
  jsr printtime
  jsr filesel_updates ; update stuff, check keys etc
  jsr cover_update    ; cover preview state machine (debounce + async load)
  lda filesel_dirty   ; is there ANY reason to redraw the menu?
  cmp #$01
  beq fileselloop_redraw ; then do
  jsr bgm_update      ; fork: start/stop menu music. Only here (not-dirty branch)
                      ; so the list is already painted before the ~1s SPC upload
                      ; freezes NMI; also stops music when toggled off.
  jsr scroll_direntry
  bra fileselloop
fileselloop_redraw
  stz filesel_dirty
  jsr filesel_statusbar
  jsr filesel_redraw
  jsr filesel_cleanup ; update phase 2
  bra fileselloop
  rts

filesel_cleanup:
  sep #$20 : .as
  rep #$10 : .xl
  lda dirend_onscreen ; end of file list on screen?
  beq filesel_cleanup_out
  lda dirend_idx
  lsr
  lsr
  pha
filesel_cleanup_loop  ; pad rest of screen with empty lines
  cmp listdisp        ; end of screen reached?
  beq +               ; then leave
  pha
  clc
  adc #$09            ; first line in text area
  inc
  sta print_y
  stz print_x
  lda #^space64
  ldx #!space64
  sta print_bank
  stx print_src
  stz print_pal
  lda #64
  sta print_count
  jsr hiprint
  pla
  inc
  bra filesel_cleanup_loop
+
  pla
  cmp filesel_sel
  beq filesel_cleanup_out
  bpl filesel_cleanup_out
  sta filesel_sel
filesel_cleanup_out
  rts

filesel_updates:
; update selection, scroll etc
  lda filesel_sel
  asl
  asl
  sta dirptr_idx
  lda filesel_sel
  clc
  adc #$08
  sta bar_yl
  lda #$3e
  sta bar_wl
  lda #$01
  sta bar_xl
; get input
  jsr read_pad
  lda pad_down
  bne key_down
  lda pad_up
  bne key_up
  lda pad_right
  bne key_right
  lda pad_left
  bne key_left
  lda pad_b
  bne key_b
  lda pad_start
  bne key_start
  lda pad_select
  bne key_select
  lda pad_a
  bne key_a
  lda pad_x
  bne key_x
  lda pad_y
  bne key_y
  lda pad_l
  bne key_l
  lda pad_r
  bne key_r
  bra fileselupd_out
key_down
  jsr filesel_key_down
  bra fileselupd_out
key_up
  jsr filesel_key_up
  bra fileselupd_out
key_right
  jsr filesel_key_right
  bra fileselupd_out
key_left
  jsr filesel_key_left
  bra fileselupd_out
key_b
  jsr filesel_key_b
  bra fileselupd_out
key_a
  jsr filesel_key_a
  bra fileselupd_out
key_x
  jsr filesel_key_x
  bra fileselupd_out
key_y
  jsr filesel_key_y
  bra fileselupd_out
key_select
  jsr filesel_key_select
  bra fileselupd_out
key_start
  jsr filesel_key_start
  bra fileselupd_out
key_l
  jsr filesel_key_l
  bra fileselupd_out
key_r
  jsr filesel_key_r
  bra fileselupd_out

fileselupd_out
  lda #$09
  sta cursor_y
  rts

filesel_redraw:
  lda filesel_state
  beq redraw_filelist
;  cmp 1
;  beq redraw_main
filesel_redraw_out
  rts

redraw_filelist
  ldy #$0000
  sty dirptr_idx
  sty direntry_fits_idx
  sty direntry_xscroll
  sty direntry_xscroll_state
  stz dirend_idx
  stz dirend_onscreen
redraw_filelist_loop
  ldy dirptr_idx
  tya
  lsr
  lsr
  cmp listdisp
  beq redraw_filelist_last
  rep #$20 : .al
  lda [dirptr_addr], y
  sta @dirent_addr
  iny
  iny
  sep #$20 : .as
  lda [dirptr_addr], y  ; load fileinfo bank
  clc
  adc #$c0              ; add $C0 for memory map
  sta @dirent_bank      ; store as current bank
  cmp #$c0              ; if bank was 0 -> dirend entry in DB
  beq redraw_filelist_dirend ; handle dirend
  iny
  lda [dirptr_addr], y
  iny
  sta @dirent_type
  sty dirptr_idx
  jsr print_direntry
  inc direntry_fits_idx
  bra redraw_filelist_loop
redraw_filelist_dirend
  dey                   ; recover last valid direntry number
  dey                   ; (we had 2x iny of the direntry pointer above,
  beq +
  dey                   ; so account for those too)
  dey
  dey
  dey
+ sty dirend_idx        ; dirend_idx <- last valid directory entry.
  lda #$01              ; encountered during redraw, so must be on screen
  sta dirend_onscreen
  bra redraw_filelist_out
redraw_filelist_last    ; check if next offscreen item is end of dir
  iny
  iny
  lda [dirptr_addr], y
  beq redraw_filelist_dirend
redraw_filelist_out
  ldx #$0000
  stx dirptr_idx
  brl filesel_redraw_out

print_direntry:
  lda cursor_y
  sta print_y
  inc
  sta cursor_y

  lda dirent_bank
  ldx dirent_addr

  phb
  pha
  plb

  rep #$20 : .al
  lda #$06      ; skip size string
  sta @fd_fnoff
  lda @dirent_type
  and #TYPE_SUBDIR|TYPE_PARENT
  beq dirent_is_file
dirent_is_dir
  lda #$01      ; different color for dirs
  bra dirent_type_cont
dirent_is_file
  lda @dirent_type
  and #$00ff
  cmp #$0001    ; SMC -> palette 0 (white)
  bne +
  lda #$0000
  bra dirent_type_cont
+
  cmp #TYPE_SPC ; SPC -> palette 2
  bne +
  lda #$0002
  bra dirent_type_cont
+
  lda #$0000    ; default -> palette 0
dirent_type_cont
  sta @print_pal
  rep #$20 : .al
  txa
  clc
  adc @fd_fnoff
  clc
  adc @direntry_xscroll
  sta @fd_fnoff
  plb

  lda cursor_x
  sta print_x

  sep #$20 : .as
  ldx fd_fnoff
  lda #54
  sta print_count
  stx print_src
  lda dirent_bank
  sta print_bank
  jsr hiprint
  lda cursor_x
  clc
  adc print_done
  sta print_x

  lda print_over
  ldy direntry_fits_idx
  sta !direntry_fits, y
  lda #54
  sec
  sbc print_done
  sta print_count
  lda #^space64
  ldx #!space64
  sta print_bank
  stx print_src
  jsr hiprint

  sep #$20 : .as
  lda dirent_type
  and #$f0
  cmp #$80
  bne dirent_is_file_2
  lda #^text_dirmark
  ldx #!text_dirmark
  sta print_bank
  stx print_src
  bra dirent_type_cont_2
dirent_is_file_2
  lda dirent_bank
  ldx dirent_addr
  sta print_bank
  stx print_src
dirent_type_cont_2
  lda #56
  sta print_x
  lda #6
  sta print_count
  jsr hiprint

  rts

filesel_key_down:
  jsr scroll_direntry_clean
  lda listdisp
  dec
  cmp filesel_sel
  bne down_noscroll
  lda #$01
  sta filesel_dirty
  lda dirend_onscreen
  bne down_out
  rep #$20 : .al
  lda dirptr_addr
  clc
  adc #$04
  bcc +
  inc dirptr_bank
+ sta dirptr_addr
  sep #$20 : .as
  rts
down_noscroll
  lda dirend_onscreen
  beq +
  lda dirend_idx
  lsr
  lsr
  cmp filesel_sel
  beq fileselupd_lastcursor
  bcc fileselupd_lastcursor
+ lda filesel_sel
  inc
  sta filesel_sel
down_out
  rts

filesel_key_up:
  jsr scroll_direntry_clean
  lda filesel_sel
  bne up_noscroll
  lda #$01
  sta filesel_dirty
  rep #$20 : .al
  lda dirptr_addr
  cmp dirstart_addr
  beq up_out
  sec
  sbc #$04
  bcs +
  dec dirptr_bank
+ sta dirptr_addr
  bra up_out
up_noscroll
  dec
  sta filesel_sel
up_out
  sep #$20 : .as
  rts

fileselupd_lastcursor
  jsr scroll_direntry_clean
  lda dirend_idx
  lsr
  lsr
  sta filesel_sel
  rts

; go back one page
filesel_key_left:
  stz direntry_xscroll
  stz direntry_xscroll_state
  lda #$01        ; must redraw afterwards
  sta filesel_dirty
  rep #$20 : .al
  lda dirptr_addr ; get current direntry pointer
  beq +           ; special case: if 0, we are at the first entry in memory
  lsr
  lsr             ; make comparable to listdisp
  cmp listdisp    ; if there's less or equal previous entries...
  beq +           ; ...than display lines, reset to directory start
  bcc +
  sec
  sbc listdisp    ; subtract one screen page's worth of entries
  asl
  asl             ; make comparable to dirstart_addr again
  cmp dirstart_addr ; check whether calculated offset is before...
  bcc +           ; ...start of directory
- sta dirptr_addr ; store new selected entry
  sep #$20 : .as
  rts
+ lda dirstart_addr ; reset pointer to start of directory
  stz filesel_sel ; reset the selection cursor too
  bra -

; go forth one page
filesel_key_right:
  stz direntry_xscroll
  stz direntry_xscroll_state
  sep #$20 : .as
  lda dirend_onscreen
  bne fileselupd_lastcursor
  lda #$01
  sta filesel_dirty
  rep #$20 : .al
  lda listdisp
  asl
  asl
  clc
  adc dirptr_addr
  sta dirptr_addr
  lda listdisp
  asl
  asl
  clc
  adc dirptr_addr
  cmp dirend_addr
  bmi +
  lda dirend_addr
  lsr
  lsr
  sec
  sbc listdisp
  asl
  asl
  sta dirptr_addr
  sep #$20 : .as
  lda listdisp
  dec
  sta filesel_sel
+ sep #$20 : .as
  rts

filesel_key_a:
  jsr select_item
  rts

filesel_key_select:
  jsr cover_menu_off    ; hide the box-art cover behind the favorite games window
  jsl select_favorite_file
  rts

filesel_key_start:
  jsr cover_menu_off    ; hide the box-art cover behind the recent games window
  jsl select_last_file
  rts

filesel_key_b:
  stz direntry_xscroll
  stz direntry_xscroll_state
  jmp sel_is_parent

filesel_key_l:
  stz direntry_xscroll
  stz direntry_xscroll_state
  ldx dirstart_addr
  stx dirptr_addr
  ldx #$0000
  stx filesel_sel
  lda #$01
  sta filesel_dirty
  rts

filesel_key_r:
  stz direntry_xscroll
  stz direntry_xscroll_state
  lda dirend_onscreen
  beq +
  jmp fileselupd_lastcursor
+ lda #$01
  sta filesel_dirty
; subtract listdisp from index to get first entry pos
; if less than one screen's worth, set to 0000, set cursor to last file
; else set cursor to listdisp
  rep #$20 : .al
  lda dirend_addr
  lsr
  lsr
  sec
  sbc dirstart_addr
  cmp listdisp ; listdisp > ptr?
  bpl +
  beq +
  stz dirptr_addr
  tya
  lsr
  lsr
  dec
  sep #$20 : .as
  sta filesel_sel
  bra filesel_key_r_out
+ sbc listdisp
  asl
  asl
  sta dirptr_addr
  sep #$20 : .as
  lda listdisp
  dec
  sta filesel_sel
filesel_key_r_out
  rts

select_item:
  rep #$20 : .al
  lda filesel_sel
  and #$00ff
  asl
  asl
  tay
  sep #$20 : .as
  iny
  iny
  iny
  lda [dirptr_addr], y
  cmp #TYPE_ROM
  beq sel_is_file
  cmp #TYPE_SPC
  beq sel_is_spc
  cmp #TYPE_SKIN
  beq sel_is_theme
  cmp #TYPE_SUBDIR
  beq sel_is_dir
  cmp #TYPE_PARENT
  beq sel_is_parent
select_item_cont
  rts
sel_is_file
  jsr ips_select_file
  bra select_item_cont
sel_is_parent
  jsr select_parent
  bra select_item_cont
sel_is_dir
  jsr select_dir
  bra select_item_cont
sel_is_spc
  jsr select_spc
  bra select_item_cont
sel_is_theme
  jsr select_theme
  bra select_item_cont

select_file:
; have MCU load the rom
  dey
  rep #$20 : .al
  lda [dirptr_addr], y
  and #$00ff
  sta @MCU_PARAM+6
  dey
  dey
  lda [dirptr_addr], y
  sta @MCU_PARAM+4
  lda #!FILESEL_CWD
  sta @MCU_PARAM
  sep #$20 : .as
  lda #^FILESEL_CWD
  sta @MCU_PARAM+2
  lda #$00
  sta @MCU_PARAM+3
  lda #CMD_LOADROM
  jsr game_handshake
  rts

select_theme:
; A .thm theme file was picked. Build MCU_PARAM exactly like select_file (cwd +
; selected dir entry, using y) FIRST so the MCU's get_selected_name yields the
; full path, then ask the MCU to apply it (CMD_SET_THEME). The MCU stores the
; choice and reloads the menu (which resets the SNES), so we use the light
; handshake like the autoboot setters -- no game_handshake/WRAM trampoline.
  dey
  rep #$20 : .al
  lda [dirptr_addr], y
  and #$00ff
  sta @MCU_PARAM+6
  dey
  dey
  lda [dirptr_addr], y
  sta @MCU_PARAM+4
  lda #!FILESEL_CWD
  sta @MCU_PARAM
  sep #$20 : .as
  lda #^FILESEL_CWD
  sta @MCU_PARAM+2
  lda #$00
  sta @MCU_PARAM+3
; channel + UI ready (MCU_PARAM is now set; cover_sync_before_cmd preserves it,
; exactly as game_handshake relies on for LOADROM)
  jsr cover_sync_before_cmd  ; drain any in-flight cover so its $55 isn't read as our ACK
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_SET_THEME
  sta @MCU_CMD
- lda @SNES_CMD
  cmp #$55
  beq +
  cmp #$aa
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  jsr pop_window
  rts

restore_theme:
; Config-menu action (Browser Options -> Restore Theme): revert the menu to the
; baked-in default look. No MCU_PARAM needed -- the MCU just clears CFG.skin_name
; and reloads the menu (which resets the SNES). Same light handshake as
; select_theme.
  jsr cover_sync_before_cmd  ; drain any in-flight cover so its $55 isn't read as our ACK
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_CLR_THEME
  sta @MCU_CMD
- lda @SNES_CMD
  cmp #$55
  beq +
  cmp #$aa
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  jsr pop_window
  rts

select_dir:
  tyx
; save old dir position
  rep #$20 : .al
  ldy #$0000
  lda @dirstart_addr
  sta [dirlog_idx], y
  iny
  iny
  lda @dirstart_bank
  sta [dirlog_idx], y
  iny
  lda @dirptr_addr
  sta [dirlog_idx], y
  iny
  iny
  lda @dirptr_bank
  sta [dirlog_idx], y
  iny
  lda @filesel_sel
  sta [dirlog_idx], y
  lda @dirlog_idx
  clc
  adc #$0008
  sta @dirlog_idx
  sep #$20 : .as
;---
; y = direntry ptr
  txy
  dey
  lda [dirptr_addr], y
  clc
  adc #$c0
  sta @dirent_bank
  dey
  dey
  rep #$20 : .al
  lda [dirptr_addr], y
  sta @dirent_addr
  tay
  sep #$20 : .as
  lda @dirent_bank
  phb
  pha
  plb
; append selected dir name to current working directory
  ldx #$0000
find_path_end:
  lda @FILESEL_CWD, x
  beq path_end_found
  inx
  bra find_path_end
path_end_found
  dex
  lda @FILESEL_CWD, x
  cmp #$2f
  beq copy_new_path
  inx
copy_new_path:
  lda #$2f
  sta @FILESEL_CWD, x
  inx
copy_new_path_loop:
  lda !6, y
  sta @FILESEL_CWD, x
  beq +
  inx
  iny
  bra copy_new_path_loop
+ lda #$00
; kill trailing /
  dex
  sta @FILESEL_CWD, x
  plb
; request directory listing
  jsr filesel_request_filelist
  rep #$20 : .al
  lda #$0000
  sta @dirptr_addr
  sta @dirstart_addr
  sep #$20 : .as
  sta @filesel_sel
  sta @direntry_xscroll
  sta @direntry_xscroll_state
  lda #$01
  sta @filesel_dirty
  rts

select_parent:
; truncate last subdirectory
  sep #$20 : .as
  ldx #$0000
- lda @FILESEL_CWD, x
  beq parent_end_found
  inx
  bra -
parent_end_found:
  cpx #$0001
  beq cwd_is_root
- lda @FILESEL_CWD, x
  cmp #$2f
  beq +
  dex
  bra -
+ cpx #$0000
  bne +
  inx
+ lda #$00
  sta @FILESEL_CWD, x
  bra parent_do_chdir
cwd_is_root:
  rts
parent_do_chdir
  jsr filesel_request_filelist
  lda @dirlog_idx
  sec
  sbc #$0008
  sta @dirlog_idx
  ldy #$0000
  lda [dirlog_idx], y ; load dirstart_addr
  sta @dirstart_addr
  iny
  iny
  sep #$20 : .as
  lda [dirlog_idx], y ; load dirstart_bank
  sta @dirstart_bank
  iny
  rep #$20 : .al
  lda [dirlog_idx], y ; load dirptr_addr
  sta @dirptr_addr
  iny
  iny
  sep #$20 : .as
  lda [dirlog_idx], y ; load dirptr_bank
  sta @dirptr_bank
  iny
  rep #$20 : .al
  lda [dirlog_idx], y ; load filesel_sel
  sta @filesel_sel
  sep #$20 : .as
  lda #$01
  sta @filesel_dirty
  rts

select_spc:
  dey
  rep #$20 : .al
  lda [dirptr_addr], y
  and #$00ff
  sta @MCU_PARAM+6
  dey
  dey
  lda [dirptr_addr], y
  sta @MCU_PARAM+4
  lda #!FILESEL_CWD
  sta @MCU_PARAM
  sep #$20 : .as
  lda #^FILESEL_CWD
  sta @MCU_PARAM+2
  lda #$00
  sta @MCU_PARAM+3
  jsr cover_sync_before_cmd ; idle the MCU channel first (see game_handshake):
                            ; SPC entries also fire covers, so a request may be
                            ; in flight when A is pressed
  lda #CMD_LOADSPC
  sta @MCU_CMD
wait_spc:
  lda @MCU_CMD
  cmp #$00
  bne wait_spc
  ; fork: with menu music off the S-SMP is at IPL -> play the chosen .spc
  ; directly (stock path). With music on the bgm is running on the S-SMP, and
  ; the only way back to IPL (which spc700_load needs) is a SNES reset. So
  ; warm-reset here, then RESUME at spc_play_now: the warm boot restores the SP
  ; and set_bank does plp;rts on the [P][return] frame we push below (the same
  ; SAVED_SP/WARM_SIGNATURE mechanism the player uses to exit in spc_key_b).
  ; apu_ram_init runs during the warm boot, so the S-SMP is back at IPL when we
  ; reach spc_play_now. The .spc staged in SDRAM survives the reset (it lives in
  ; MCU-managed SDRAM, untouched by the SNES reset).
  lda @BGM_STATE         ; only pause+warm-reset if the bgm is actually playing
  cmp #$01               ; (config on but no menu.spc -> APU already at IPL)
  bne spc_play_now
  ; Build the frame set_bank's `plp; rts` will unwind on the warm boot: push the
  ; resume address (spc_play_now-1, all menu code is bank $c0 so a near rts is
  ; fine) then the P byte, then snapshot SP into SAVED_SP. pea pushes a 16-bit
  ; value regardless of the M flag (same idiom as `pea !CFG_BSX_TIME`).
  pea !(spc_play_now-1)
  php
  rep #$20 : .al
  tsc
  sta @SAVED_SP
  lda #$fa50
  sta @WARM_SIGNATURE
  eor #$ffff
  sta @WARM_COMPLEMENT
  sep #$20 : .as
  sei
  stz $2100
  jsr backup_wram
  lda #CMD_RESET
  sta @MCU_CMD
-
  bra -
spc_play_now:
  jsr spcplayer
  jsr menu_bgm_load     ; back from the player (S-SMP at IPL): restore the bgm.
                        ; no-op when music is off. spcplayer normally exits via
                        ; its own warm reset, whose set_bank rts lands here.
  rts

;---------------------------------------
; bgm_update (fork): called once per fileselloop frame. Lazily starts the menu
; music the FIRST time (so the file list paints before the ~1s SPC upload freezes
; NMI), and stops it when the user turns the option off mid-menu. Stopping a
; running S-SMP is only possible with a SNES reset, so the off-path warm-resets
; (apu_ram_init silences the APU during the warm boot) and resumes right here.
bgm_update:
  php
  sep #$20 : .as
  rep #$10 : .xl
  lda @CFG_ENABLE_MENU_MUSIC
  beq bgm_upd_disabled
  ; enabled: load once. BGM_STATE 0 = not attempted yet this session.
  lda @BGM_STATE
  bne bgm_upd_done         ; 1=playing or 2=tried -> nothing to do
  jsr menu_bgm_load        ; list is visible now; sets BGM_STATE to 1 or 2
  bra bgm_upd_done
bgm_upd_disabled:
  lda @BGM_STATE
  cmp #$01
  bne bgm_upd_setidle      ; nothing playing -> just clear the attempt flag
  ; music is playing but now disabled -> warm-reset to silence the S-SMP
  lda #$00                 ; (snescom stz has no long mode -> lda #0 : sta)
  sta @BGM_STATE           ; will be silent after the reset
  jsr bgm_silence_reset    ; resumes here after the warm boot (APU back at IPL)
  sep #$20 : .as
  lda #$01
  sta filesel_dirty        ; warm boot cleared VRAM -> force a browser repaint
  bra bgm_upd_done
bgm_upd_setidle:
  lda #$00                 ; re-enabling later triggers a fresh load attempt
  sta @BGM_STATE
bgm_upd_done:
  plp
  rts

;---------------------------------------
; bgm_silence_reset (fork): warm-reset the SNES to return the S-SMP to IPL -- the
; only way to stop a running SPC. Mirrors spc_key_b: snapshot SP, set the warm
; signature, back up WRAM, issue CMD_RESET. The jsr return address already on the
; stack (plus the P byte we push) is what set_bank's `plp; rts` unwinds after the
; warm boot, so execution resumes in bgm_update right after the call.
bgm_silence_reset:
  php                      ; P byte for set_bank's plp on the warm boot
  rep #$20 : .al
  tsc
  sta @SAVED_SP
  lda #$fa50
  sta @WARM_SIGNATURE
  eor #$ffff
  sta @WARM_COMPLEMENT
  sep #$20 : .as
  sei
  stz $2100
  jsr backup_wram
  lda #CMD_RESET
  sta @MCU_CMD
-
  bra -

filesel_key_x:
  jsr cover_menu_off    ; hide the box-art cover behind the menu (reloads on close)
  jsr mainmenu
  sep #$20 : .as
  lda #$01              ; the menu may have switched language -> redraw browser
  sta filesel_dirty     ; chrome (statusbar) so it follows the new language too
  rts

filesel_key_y:
  jsr cover_menu_off    ; hide the box-art cover behind the context menu
  jsr open_context_menu
  rts

open_context_menu:
  jsr cover_sync_before_cmd
  rep #$20 : .al
  lda filesel_sel
  and #$00ff
  asl
  asl
  tay
  sep #$20 : .as
  iny
  iny
  iny
  lda [dirptr_addr], y
  cmp #TYPE_ROM
  beq ctx_is_file
  cmp #TYPE_SPC
  beq ctx_is_spc
  cmp #TYPE_SUBDIR
  beq ctx_is_dir
  cmp #TYPE_PARENT
  beq ctx_is_parent
open_context_menu_cont
  rts
ctx_is_file
; "save" selected file path to MCU_PARAM in case we need to send it there later
  dey
  rep #$20 : .al
  lda [dirptr_addr], y
  and #$00ff
  sta @MCU_PARAM+6
  dey
  dey
  lda [dirptr_addr], y
  sta @MCU_PARAM+4
  lda #!FILESEL_CWD
  sta @MCU_PARAM
  sep #$20 : .as
  lda #^FILESEL_CWD
  sta @MCU_PARAM+2
  lda #$00
  sta @MCU_PARAM+3
  jsr filesel_contextmenu_file
  bra open_context_menu_cont
ctx_is_parent
  bra open_context_menu_cont
ctx_is_dir
  bra open_context_menu_cont
ctx_is_spc
; set up MCU_PARAM with the SPC file path (same layout as ctx_is_file)
  dey
  rep #$20 : .al
  lda [dirptr_addr], y
  and #$00ff
  sta @MCU_PARAM+6
  dey
  dey
  lda [dirptr_addr], y
  sta @MCU_PARAM+4
  lda #!FILESEL_CWD
  sta @MCU_PARAM
  sep #$20 : .as
  lda #^FILESEL_CWD
  sta @MCU_PARAM+2
  lda #$00
  sta @MCU_PARAM+3
  jsr filesel_contextmenu_spc
  bra open_context_menu_cont

delete_selected_file:
; Browser context.  MCU_PARAM already holds the FILESEL_CWD pointer +
; the selected direntry (set by ctx_is_file / ctx_is_spc), which is what
; get_selected_name() reads on the MCU.  Ask for confirmation first; on
; ACK, refresh the listing but keep the cursor near the deleted file
; instead of jumping back to the top.
  php
  phb
  sep #$20 : .as
  rep #$10 : .xl
; confirm name = direntry file name: addr (MCU_PARAM+4)+6, bank (MCU_PARAM+6)+$C0
  rep #$20 : .al
  lda @MCU_PARAM+4
  clc
  adc #$0006
  sta confirm_name_addr
  sep #$20 : .as
  lda @MCU_PARAM+6
  clc
  adc #$c0
  sta confirm_name_bank
  lda #^text_confirm_delete_file
  sta confirm_prompt_bank
  ldx #!text_confirm_delete_file
  stx confirm_prompt_addr
  jsr confirm_delete
  bcs delete_file_go
  plb
  plp
  rtl
delete_file_go:
  lda #$01
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_DELETE_FILE
  sta @MCU_CMD
; wait for ACK/NACK
- lda @SNES_CMD
  cmp #$55
  beq delete_file_ack
  cmp #$aa
  beq delete_file_ack
  bra -
delete_file_ack:
  pha               ; save ACK/NACK value
  lda #$55
  sta @MCU_CMD
  jsr pop_window
  pla               ; restore ACK/NACK value
  cmp #$55
  bne delete_file_done  ; NACK: skip refresh
; ACK: refresh the directory listing (file is gone), keep cursor position
  jsr filesel_request_filelist
  jsr filesel_fix_pos_after_delete
  sep #$20 : .as
  lda #$00
  sta @direntry_xscroll
  sta @direntry_xscroll_state
  lda #$01
  sta @filesel_dirty
delete_file_done:
  plb
  plp
  rtl

delete_selected_srm:
; Browser context.  MCU_PARAM holds the selected ROM path (set by
; ctx_is_file).  Confirm, then delete only the .srm; the ROM list does
; not change so no refresh is needed.
  php
  phb
  sep #$20 : .as
  rep #$10 : .xl
  rep #$20 : .al
  lda @MCU_PARAM+4
  clc
  adc #$0006
  sta confirm_name_addr
  sep #$20 : .as
  lda @MCU_PARAM+6
  clc
  adc #$c0
  sta confirm_name_bank
  lda #^text_confirm_delete_srm
  sta confirm_prompt_bank
  ldx #!text_confirm_delete_srm
  stx confirm_prompt_addr
  jsr confirm_delete
  bcs delete_srm_go
  plb
  plp
  rtl
delete_srm_go:
  lda #$01
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_DELETE_SRM
  sta @MCU_CMD
- lda @SNES_CMD
  cmp #$55
  beq +
  cmp #$aa
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  jsr pop_window
  plb
  plp
  rtl

; ----------------------------------------------------------------------
; Favorites context deletes.  MCU_PARAM low byte = favorite list index
; (set by select_favorite_file).  The firmware resolves the path via
; cfg_get_listed_game(FAVORITES_FILE, ...).  Deleting the ROM also drops
; the favorites entry (firmware side), so the list is marked dirty for a
; redraw; deleting only the save leaves the entry in place.
; ----------------------------------------------------------------------
delete_favorite_file:
  php
  phb
  sep #$20 : .as
  rep #$10 : .xl
; confirm name = FAVORITE_GAMES + idx*256
  rep #$20 : .al
  lda @MCU_PARAM
  and #$00ff
  xba                          ; idx -> idx*256
  clc
  adc #!FAVORITE_GAMES
  sta confirm_name_addr
  sep #$20 : .as
  lda #^FAVORITE_GAMES
  sta confirm_name_bank
  lda #^text_confirm_delete_file
  sta confirm_prompt_bank
  ldx #!text_confirm_delete_file
  stx confirm_prompt_addr
  jsr confirm_delete
  bcs +
  plb
  plp
  rtl
+ lda #$01
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_DELETE_FILE_FAV
  sta @MCU_CMD
- lda @SNES_CMD
  cmp #$55
  beq +
  cmp #$aa
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  lda #$01
  sta listsel_dirty            ; entry removed -> redraw the favorites list
  jsr pop_window
; The deleted ROM may still be listed in the browser's current folder
; (the directory buffer is stale).  Re-read it now so the file vanishes
; there too; otherwise opening the now-missing ROM hangs on "Loading...".
  jsr filesel_request_filelist
  jsr filesel_fix_pos_after_delete
  sep #$20 : .as
  lda #$01
  sta @filesel_dirty
  plb
  plp
  rtl

delete_favorite_srm:
  php
  phb
  sep #$20 : .as
  rep #$10 : .xl
  rep #$20 : .al
  lda @MCU_PARAM
  and #$00ff
  xba
  clc
  adc #!FAVORITE_GAMES
  sta confirm_name_addr
  sep #$20 : .as
  lda #^FAVORITE_GAMES
  sta confirm_name_bank
  lda #^text_confirm_delete_srm
  sta confirm_prompt_bank
  ldx #!text_confirm_delete_srm
  stx confirm_prompt_addr
  jsr confirm_delete
  bcs +
  plb
  plp
  rtl
+ lda #$01
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_DELETE_SRM_FAV
  sta @MCU_CMD
- lda @SNES_CMD
  cmp #$55
  beq +
  cmp #$aa
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  jsr pop_window
  plb
  plp
  rtl

; ----------------------------------------------------------------------
; Recents context deletes.  MCU_PARAM low byte = recent list index (set
; by select_last_file).  Firmware resolves the path via
; cfg_get_listed_game(LAST_FILE, ...).  Same dirty/no-dirty split as
; favorites.
; ----------------------------------------------------------------------
delete_recent_file:
  php
  phb
  sep #$20 : .as
  rep #$10 : .xl
; confirm name = LAST_GAME + idx*256
  rep #$20 : .al
  lda @MCU_PARAM
  and #$00ff
  xba
  clc
  adc #!LAST_GAME
  sta confirm_name_addr
  sep #$20 : .as
  lda #^LAST_GAME
  sta confirm_name_bank
  lda #^text_confirm_delete_file
  sta confirm_prompt_bank
  ldx #!text_confirm_delete_file
  stx confirm_prompt_addr
  jsr confirm_delete
  bcs +
  plb
  plp
  rtl
+ lda #$01
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_DELETE_FILE_RECENT
  sta @MCU_CMD
- lda @SNES_CMD
  cmp #$55
  beq +
  cmp #$aa
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  lda #$01
  sta listsel_dirty            ; entry removed -> redraw the recents list
  jsr pop_window
; Same as the favorites case: drop the now-stale browser entry so the
; deleted ROM can't be opened (and hang) from the current folder.
  jsr filesel_request_filelist
  jsr filesel_fix_pos_after_delete
  sep #$20 : .as
  lda #$01
  sta @filesel_dirty
  plb
  plp
  rtl

delete_recent_srm:
  php
  phb
  sep #$20 : .as
  rep #$10 : .xl
  rep #$20 : .al
  lda @MCU_PARAM
  and #$00ff
  xba
  clc
  adc #!LAST_GAME
  sta confirm_name_addr
  sep #$20 : .as
  lda #^LAST_GAME
  sta confirm_name_bank
  lda #^text_confirm_delete_srm
  sta confirm_prompt_bank
  ldx #!text_confirm_delete_srm
  stx confirm_prompt_addr
  jsr confirm_delete
  bcs +
  plb
  plp
  rtl
+ lda #$01
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_DELETE_SRM_RECENT
  sta @MCU_CMD
- lda @SNES_CMD
  cmp #$55
  beq +
  cmp #$aa
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  jsr pop_window
  plb
  plp
  rtl

; ----------------------------------------------------------------------
; confirm_delete: modal Yes/No confirmation box, default "No".
;   in:  confirm_prompt_bank/confirm_prompt_addr = prompt line
;        confirm_name_bank/confirm_name_addr     = file name to show
;                                                  ($00 bank -> blank line)
;   out: carry set   = confirmed (Yes)
;        carry clear = cancelled (No / B)
; Enters and exits in .as/.xl.  Draws its own window and parks the
; hardware selection bar so nothing bleeds through the popup.
; ----------------------------------------------------------------------
confirm_delete:
  sep #$20 : .as
  rep #$10 : .xl
  stz confirm_sel                  ; default = No
; park the selection bar off-screen
  lda bar_xl
  pha
  lda bar_yl
  pha
  lda bar_wl
  pha
  lda #$ff
  sta bar_xl
  sta bar_yl
  sta bar_wl
; closed-border box: 44 wide, x=10, y=11, h=8
; rows: top | prompt | name | blank | options | blank | hint | bottom
  lda #10
  sta window_x
  lda #11
  sta window_y
  lda #44
  sta window_w
  lda #$08
  sta window_h
  lda #^zero
  sta window_tbank
  ldx #!zero
  stx window_taddr
  jsr push_window
  jsr draw_window
; prompt on window_y+1
  lda confirm_prompt_bank
  sta print_bank
  ldx confirm_prompt_addr
  stx print_src
  lda window_y
  inc
  sta print_y
  jsr confirm_center_print
; file name on window_y+2 (skip if bank 0)
  lda confirm_name_bank
  beq confirm_no_name
  sta print_bank
  ldx confirm_name_addr
  stx print_src
  lda window_y
  clc
  adc #$02
  sta print_y
  jsr confirm_center_print
confirm_no_name:
; hint on window_y+6 (blank row at window_y+5 separates it from the options)
  lda #^text_confirm_hint
  sta print_bank
  ldx #!text_confirm_hint
  stx print_src
  lda window_y
  clc
  adc #$06
  sta print_y
  jsr confirm_center_print
; options on window_y+4
  jsr confirm_redraw_opts
  jsr enable_screen_update
confirm_loop:
  lda isr_done
  beq confirm_loop
  stz isr_done
  jsr printtime
  jsr read_pad
  lda pad_b
  bne confirm_cancel
  lda pad_a
  bne confirm_finish               ; A accepts the current option
  lda pad_left
  ora pad_right
  ora pad_up
  ora pad_down
  bne confirm_toggle
  bra confirm_loop
confirm_toggle:
  lda confirm_sel
  eor #$01
  sta confirm_sel
  jsr confirm_redraw_opts
  bra confirm_loop
confirm_cancel:
  stz confirm_sel                  ; B -> No
confirm_finish:
  jsr pop_window
  pla
  sta bar_wl
  pla
  sta bar_yl
  pla
  sta bar_xl
  lda confirm_sel
  beq confirm_ret_no
  sec
  rts
confirm_ret_no:
  clc
  rts

; ----------------------------------------------------------------------
; confirm_redraw_opts: (re)draw the [No]/[Yes] option line.  The selected
; option uses the bracketed string, the other the spaced one; both states
; are the same width so toggling overwrites cleanly.  print_y is computed
; from window_y so it tracks the box.
; ----------------------------------------------------------------------
confirm_redraw_opts:
  php
  sep #$20 : .as
  rep #$10 : .xl
  lda window_y
  clc
  adc #$04
  sta print_y
; No option at col 22
  lda confirm_sel
  bne cro_no_unsel
  lda #^text_confirm_no_sel
  sta print_bank
  ldx #!text_confirm_no_sel
  stx print_src
  bra cro_no_draw
cro_no_unsel:
  lda #^text_confirm_no_unsel
  sta print_bank
  ldx #!text_confirm_no_unsel
  stx print_src
cro_no_draw:
  stz print_pal
  lda #$06
  sta print_count
  lda #22
  sta print_x
  jsr hiprint
; Yes option at col 36
  lda confirm_sel
  beq cro_yes_unsel
  lda #^text_confirm_yes_sel
  sta print_bank
  ldx #!text_confirm_yes_sel
  stx print_src
  bra cro_yes_draw
cro_yes_unsel:
  lda #^text_confirm_yes_unsel
  sta print_bank
  ldx #!text_confirm_yes_unsel
  stx print_src
cro_yes_draw:
  stz print_pal
  lda #$06
  sta print_count
  lda #36
  sta print_x
  jsr hiprint
  plp
  rts

; ----------------------------------------------------------------------
; confirm_center_print: center print_bank/print_src (a const_lang or raw
; pointer) on row print_y inside the current window_x/window_w box.
; Mirrors the centering in show_empty_msg.  Enters/exits in .as/.xl.
; ----------------------------------------------------------------------
confirm_center_print:
  php
  sep #$20 : .as
  rep #$10 : .xl
  lda print_bank
  ldy print_src
  jsr resolve_yx                   ; resolves print_*; A=bank, Y=addr
  phb
  pha
  plb
  jsr strlen                       ; Y = length
  plb
  sep #$20 : .as
  tya
  sta window_tmp                   ; window_tmp = string length
; Keep a 1-col blank margin inside each border.  If the string is wider than the
; padded interior (window_w - 4), truncate it to (window_w - 7) chars and append
; "..." so it never spills past the margin/border.
  lda window_w
  sec
  sbc #$04                         ; padded interior width (1-col margin each side)
  cmp window_tmp
  bcc confirm_print_trunc          ; padded interior < length -> truncate + ellipsis
; fits: centre it
  lda window_w
  sec
  sbc window_tmp                   ; window_w - length
  lsr                              ; /2
  clc
  adc window_x
  sta print_x
  stz print_pal
  lda #56
  sta print_count
  jsr hiprint
  plp
  rts
confirm_print_trunc:
  lda window_x                     ; left edge + 1-col margin
  clc
  adc #$02
  sta print_x
  stz print_pal
  lda window_w
  sec
  sbc #$07                         ; name chars = padded interior - 3 ("...")
  sta print_count
  jsr hiprint                      ; print_bank/print_src still point at the name
  lda window_x                     ; "..." right after the truncated name
  clc
  adc window_w
  sec
  sbc #$05                         ; = window_x + window_w - 5 (1-col right margin)
  sta print_x
  lda #^confirm_ellipsis
  sta print_bank
  ldx #!confirm_ellipsis
  stx print_src
  lda #$03
  sta print_count
  jsr hiprint
  plp
  rts
confirm_ellipsis .byt "...", 0

; ----------------------------------------------------------------------
; filesel_fix_pos_after_delete: keep the cursor near the deleted entry.  Keep the
; page top (dirptr_addr) where it was if it still falls inside the (now shorter)
; listing; otherwise fall back to the top.  The redraw's filesel_cleanup then
; clamps filesel_sel down if it points past the new last entry, so the cursor
; lands on the entry that took the deleted one's place (or the new last).
; This relies on dirend_addr being correct, which filesel_request_filelist now
; guarantees by taking it from the firmware's authoritative entry count (it used
; to scan the SDRAM dir table from the SNES, which could read a stale/partial
; buffer and yield a too-short dirend -> corrupted navigation).
; ----------------------------------------------------------------------
filesel_fix_pos_after_delete:
  php
  rep #$20 : .al
  lda @dirptr_addr
  cmp @dirend_addr
  bcc fix_pos_done                 ; page top still within the dir -> keep position
; page top is past the new (shrunken) end -> snap to the LAST page so the cursor
; stays near the bottom, instead of jumping all the way to the top.
  lda @dirend_addr
  lsr
  lsr                              ; A = entry count
  cmp #18                          ; listdisp (visible rows)
  bcs +                            ; count >= one page -> last page = (count-18)*4
  lda #0                           ; stz has no long (@) addressing mode on 65816;
  sta @dirptr_addr                 ; A is 16-bit here & dead after -> lda#0/sta@ == stz
  bra fix_pos_done
+ sec
  sbc #18
  asl
  asl
  sta @dirptr_addr
fix_pos_done:
  sep #$20 : .as
  plp
  rts

setup_224:
  php
  rep #$30 : .xl : .al
  lda #18
  sta listdisp
  dec
  cmp filesel_sel
  bmi setup_224_adjsel
  bra +
setup_224_adjsel
  sta filesel_sel
+
  sep #$20 : .as
  lda #$0b
  sta $2110
  lda #$00
  sta $2110
  ora #$08
  sta $2133
  lda #$01
  sta filesel_dirty
  lda #^space64
  ldx #!space64
  sta print_bank
  stx print_src
  stz print_pal
  lda #64
  sta print_count
  lda #27
  sta print_y
  stz print_x
  jsr hiprint
  lda #28
  sta print_y
  jsr hiprint
  jsr hiprint

  plp
  rts

filesel_statusbar
  pha
  phx
  php
  sep #$20 : .as
  rep #$10 : .xl
  ; clear the keys field first (x=$02..$2a, up to the clock at x=$2b) so a shorter
  ; localized string after a language switch leaves no trailing characters.
  lda #^space64
  sta @print_bank
  rep #$20 : .al
  lda #!space64
  sta @print_src
  sep #$20 : .as
  lda #$00
  sta @print_pal
  lda #$02
  sta @print_x
  lda #$29
  sta @print_count
  lda listdisp
  clc
  adc #$0a
  sta @print_y
  jsr hiprint
  lda #^text_statusbar_keys
  sta @print_bank
  rep #$20 : .al
  lda #!text_statusbar_keys
  sta @print_src
  sep #$20 : .as
  lda #$00
  sta @print_pal
  lda #$02
  sta @print_x
  lda #$40
  sta @print_count
  lda listdisp
  clc
  adc #$0a
  sta @print_y
  jsr hiprint
  plp
  plx
  pla
  rts

; show_empty_msg: pop up a small centered message box (closed border, NO title)
; with the message text centered INSIDE the box, then wait for A/B/Start/Select
; before closing. The caller passes the message string pointer in
; window_tbank/window_taddr (a const_lang dispatch table is fine -> resolved here).
; Used for the empty Recent/Favorite lists so the keypress that opened the list
; gives visible feedback. Enters in .as/.xl with DBR=$7e.
show_empty_msg:
  php
  sep #$20 : .as
  rep #$10 : .xl
  lda bar_xl              ; the select bar is a hardware colour window (drawn by the
  pha                     ; NMI from bar_xl/yl/wl), not a tile, so push_window can't
  lda bar_yl              ; hide it -> save it and park it off-screen ($ff, like
  pha                     ; spcplayer) so it doesn't bleed under the popup border
  lda bar_wl
  pha
  lda #$ff
  sta bar_xl
  sta bar_yl
  sta bar_wl
  lda window_tbank        ; stash the caller's message pointer across draw_window
  pha
  rep #$20 : .al
  lda window_taddr
  pha
  sep #$20 : .as
  lda #20
  sta window_x
  lda #13
  sta window_y
  lda #24
  sta window_w
  lda #3
  sta window_h
  lda #^zero              ; empty title -> draw_window draws a closed top border
  sta window_tbank
  ldx #!zero
  stx window_taddr
  jsr push_window
  jsr draw_window
  rep #$20 : .al          ; recover the message pointer into print_src/print_bank
  pla
  sta print_src
  sep #$20 : .as
  pla
  sta print_bank
  lda print_bank          ; resolve language + measure length to center it
  ldy print_src
  jsr resolve_yx          ; A=resolved bank, Y=resolved addr; print_* now resolved
  phb
  pha
  plb                     ; DB = resolved string bank (for strlen)
  jsr strlen              ; Y = string length
  plb                     ; restore DB
  sep #$20 : .as
  tya                     ; A = length (always < 256)
  sta window_tmp          ; draw_window is done, so window_tmp is free scratch
  lda window_w
  sec
  sbc window_tmp          ; window_w - length
  bcs +                   ; box wide enough
  lda #$02                ; message wider than box (long translation): small
                          ; left margin instead of an underflowed print_x
+ lsr                     ; / 2
  clc
  adc window_x            ; print_x = window_x + (window_w - length)/2  (centered)
  sta print_x
  lda window_y
  inc                     ; print_y = body row (window_y + 1, for h=3)
  sta print_y
  stz print_pal           ; palette 0 (white), same as list text
  lda #56
  sta print_count
  jsr hiprint             ; draw the message INSIDE the box
  jsr enable_screen_update
show_empty_msg_wait:
  lda isr_done
  beq show_empty_msg_wait
  stz isr_done
  jsr printtime
  jsr read_pad
  lda pad_a
  ora pad_b
  ora pad_start
  ora pad_select
  beq show_empty_msg_wait
  jsr pop_window
  pla                     ; restore the selection bar for the underlying menu/list
  sta bar_wl
  pla
  sta bar_yl
  pla
  sta bar_xl
  plp
  rts

select_last_file:
  php
  sep #$20 : .as
  rep #$10 : .xl
  lda #$00
  sta listsel_backup
  lda @ST_NUM_RECENT_GAMES       ; first open: if the list is empty, show the message
  bne select_last_redraw
  lda #^text_no_last
  sta window_tbank
  ldx #!text_no_last
  stx window_taddr
  jsr show_empty_msg
  jmp select_last_file_out
select_last_redraw:               ; redraw after a remove: if now empty, just close
  lda @ST_NUM_RECENT_GAMES
  sta num_recent_games
  stz recent_sel
  bne +
  jmp select_last_file_out
+ lda #^text_last
  sta window_tbank
  ldx #!text_last
  stx window_taddr
  lda @last_win_x
  sta window_x
  inc
  inc
  pha
  lda @last_win_y
  sta window_y
  inc
  pha
  lda @last_win_w
  sta window_w
  lda @ST_NUM_RECENT_GAMES
  inc
  inc
  sta window_h
  jsr push_window
  lda num_recent_games
  sta listsel_max
  dec
  cmp listsel_backup
  bcs +
  sta listsel_backup
+ lda listsel_backup
  sta listsel_sel
  jsr draw_window
  stz print_pal
  lda #^LAST_GAME
  ldx #!LAST_GAME
  sta print_bank
  stx print_src
  stz print_pal
  pla
  sta print_y
  pla
  sta print_x
- lda #56
  sta print_count
  jsr hiprint
  inc print_src+1
  inc print_y
  dec num_recent_games
  bne -
  stz listsel_dirty
  jsr enable_screen_update
select_last_choose:
  lda #$01
  sta listsel_step
  sta listsel_pickbutton ; allow button Y
  jsr listcover_list_enabled ; cover follows the highlighted entry only if allowed
  lda #$00
  bcs +
  lda #$01
+ sta listcover_active
  stz listcover_which        ; 0 = recent
  lda #$ff
  sta listcover_lastsel      ; force a cover load for the current selection
  stz cover_request_pending
  stz cover_dirty
  stz cover_debounce
  jsr menu_select_noinit
  stz listcover_active       ; stop the per-frame hook before any context menu/command
  pha                        ; save the selection index (cover_sync clobbers A)
  jsr cover_sync_before_cmd  ; drain any in-flight cover load so the channel is idle
  pla
  sta listsel_backup
  sta @MCU_PARAM
  cmp #$ff
  beq select_last_file_done
  lda listsel_pickbutton
  cmp #$00 ; button A was pressed
  beq select_last_file_play
  cmp #$01 ; button Y was pressed
  beq select_last_file_context_menu
  bra select_last_file_done
select_last_file_play:
  sep #$20 : .as
  lda #CMD_LOADLAST
  jsr game_handshake
  bra select_favorite_file_done
select_last_file_context_menu:
  jsr cover_menu_off         ; hide the floating box-art cover so it doesn't
                             ; float over the context / cheat windows (it
                             ; reloads when we return to the recents list)
  jsr filesel_recent_contextmenu
  lda listsel_dirty
  bne +
  jmp select_last_choose
+ stz listsel_dirty
  jsr pop_window
  jsr disable_screen_update
  jmp select_last_redraw
select_last_file_done:
  jsr pop_window
select_last_file_out:
  stz listcover_active       ; leaving the list -> reload the browser cover
  lda cover_loaded
  beq +
  jsr cover_hide
+ jsr enable_screen_update
  plp
  rtl

select_favorite_file:
; shows a window with a list of favorite games
  php
  sep #$20 : .as
  rep #$10 : .xl
  lda #$00
  sta listsel_backup
  lda @ST_NUM_FAVORITE_GAMES     ; first open: if the list is empty, show the message
  bne select_favorite_redraw
  lda #^text_no_favorite
  sta window_tbank
  ldx #!text_no_favorite
  stx window_taddr
  jsr show_empty_msg
  jmp select_favorite_file_out
select_favorite_redraw:           ; redraw after a remove: if now empty, just close
  lda @ST_NUM_FAVORITE_GAMES
  bne +
  jmp select_favorite_file_out
+ sta num_favorite_games
  lda #^text_favorite
  sta window_tbank
  ldx #!text_favorite
  stx window_taddr
  lda @last_win_x
  sta window_x
  inc
  inc
  pha
  lda @last_win_y
  sta window_y
  inc
  pha
  lda @last_win_w
  sta window_w
  lda num_favorite_games
  inc
  inc
  sta window_h
  jsr push_window
  lda num_favorite_games
  sta listsel_max
  dec ; listsel_max is an element count but listsel_sel is 0..max-1
  cmp listsel_backup
  bcs +
  sta listsel_backup
+ lda listsel_backup
  sta listsel_sel
  jsr draw_window
  stz print_pal
  lda #^FAVORITE_GAMES
  ldx #!FAVORITE_GAMES
  sta print_bank
  stx print_src
  stz print_pal
  pla
  sta print_y
  pla
  sta print_x
- lda #56
  sta print_count
  jsr hiprint
  inc print_src+1
  inc print_y
  dec num_favorite_games
  bne -
  stz listsel_dirty
  jsr enable_screen_update
select_favorite_choose:
  lda #$01
  sta listsel_step
  sta listsel_pickbutton ; allow button Y
  lda #$01
  sta listcover_which        ; 1 = favorite
  jsr listcover_list_enabled ; cover follows the highlighted entry only if allowed
  lda #$00
  bcs +
  lda #$01
+ sta listcover_active
  lda #$ff
  sta listcover_lastsel      ; force a cover load for the current selection
  stz cover_request_pending
  stz cover_dirty
  stz cover_debounce
  jsr menu_select_noinit
  stz listcover_active       ; stop the per-frame hook before any context menu/command
  pha                        ; save the selection index (cover_sync clobbers A)
  jsr cover_sync_before_cmd  ; drain any in-flight cover load so the channel is idle
  pla
  sta listsel_backup
  sta @MCU_PARAM ; store selected item index in mcu param
  cmp #$ff ; if no selected item, do nothing
  beq select_favorite_file_done
  lda listsel_pickbutton
  cmp #$00 ; if button A was pressed
  beq select_favorite_file_play
  cmp #$01 ; if button Y was pressed
  beq select_favorite_file_context_menu
  bra select_favorite_file_done ; unknown button was pressed
select_favorite_file_play
  sep #$20 : .as
  lda #CMD_LOADFAVORITE
  jsr game_handshake
  bra select_favorite_file_done
select_favorite_file_context_menu
  jsr cover_menu_off         ; hide the floating box-art cover so it doesn't
                             ; float over the context / cheat windows (it
                             ; reloads when we return to the favorites list)
  jsr filesel_favorites_contextmenu
  lda listsel_dirty          ; need redraw?
  bne +
  jmp select_favorite_choose ; return to previous view
+ stz listsel_dirty
  jsr pop_window
  jsr disable_screen_update
  jmp select_favorite_redraw   ; redraw favorite list
select_favorite_file_done
  jsr pop_window
select_favorite_file_out
  stz listcover_active       ; leaving the list -> reload the browser cover
  lda cover_loaded
  beq +
  jsr cover_hide
+ jsr enable_screen_update
  plp
  rtl

; TODO the following seven functions differ only in the command byte
;      sent to the MCU and whether the listsel_dirty flag is set.
;      consider merging!
add_selected_file_to_favorites:
; have MCU save the file to the favorites list
; the file path should already have been saved to MCU_PARAM before calling
; this routine
  php
  phb
  sep #$20 : .as
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_ADD_FAVORITE_ROM
  sta @MCU_CMD
; wait for ACK/NACK
- lda @SNES_CMD
  cmp #$55
; success
  beq +
  cmp #$aa
; failure
  beq +
  bra -
+ lda #$55
  sta @MCU_CMD
  jsr pop_window
  plb
  plp
  rtl

add_recent_file_to_favorites:
; have MCU remove the file from the recent list
; the list index of the file should already have been saved to MCU_PARAM before
; calling this routine
  php
  phb
  sep #$20 : .as
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_ADD_FAVORITE_RECENT
  sta @MCU_CMD
  ; wait for ACK/NACK
  - lda @SNES_CMD
  cmp #$55
  ; success
  beq +
  cmp #$aa
  ; failure
  beq +
  bra -
  + lda #$55
  sta @MCU_CMD
;  sta listsel_dirty
  jsr pop_window
  plb
  plp
  rtl

remove_selected_recent_file:
; have MCU remove the file from the recent list
; the list index of the file should already have been saved to MCU_PARAM before
; calling this routine
  php
  phb
  sep #$20 : .as
  jsr hide_cursor
  jsr draw_loading_window
  jsr waitblank
  lda #$00
  sta @SNES_CMD
  lda #CMD_REMOVE_RECENT_ROM
  sta @MCU_CMD
  ; wait for ACK/NACK
  - lda @SNES_CMD
  cmp #$55
  ; success
  beq +
  cmp #$aa
  ; failure
  beq +
  bra -
  + lda #$55
  sta @MCU_CMD
  lda #$01
  sta listsel_dirty
  jsr pop_window
  plb
  plp
  rtl

remove_selected_favorite_file:
; have MCU remove the file from the favorites list
